#!/bin/sh
# Opcional: git config core.hooksPath githooks
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
if command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$ROOT/scripts/pre-push-check.ps1"
  exit $?
fi
if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File "$ROOT/scripts/pre-push-check.ps1"
  exit $?
fi
echo "pre-push-check: PowerShell nao encontrado — skip"
exit 0
